<Window x:Class="VisualSportCut.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VisualSportCut"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        xmlns:vm="clr-namespace:VisualSportCut.Presentation.ViewModels"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ✅ Добавляем две колонки: 3* для графика, 1* для круговой -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель управления (на всю ширину) -->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="📂 Загрузить JSON" 
                Command="{Binding LoadFileCommand}"
                Padding="15,8"/>
            <ComboBox ItemsSource="{Binding AvailableGroups}"
                  SelectedItem="{Binding SelectedTag}"
                  Margin="20,0,0,0"
                  Width="200">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDataLoaded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Style>
            </ComboBox>
        </StackPanel>


        <lvc:PieChart Grid.Row="1" Grid.Column="0"
                  Series="{Binding PieSeries}"
                  LegendPosition="Bottom"
                  Margin="10,0,0,0"/>

        <lvc:CartesianChart Grid.Row="1" Grid.Column="1"
                        TooltipFindingStrategy="CompareOnlyXTakeClosest"
                        Series="{Binding ChartSeries}"
                        XAxes="{Binding XAxes}"
                        ZoomMode="X"
                        Margin="0,0,10,0"/>

    </Grid>
</Window>