<Window Background="#1E1E1E" x:Class="VisualSportCut.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VisualSportCut"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        xmlns:vm="clr-namespace:VisualSportCut.Presentation.ViewModels"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:lvcore="clr-namespace:LiveChartsCore;assembly=LiveChartsCore">

    <Grid Background="#1E1E1E" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="0.4*"/>
        </Grid.RowDefinitions>


        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="📂 Загрузить JSON" 
                Command="{Binding LoadFileCommand}"
                Padding="15,8"/>
            <ComboBox ItemsSource="{Binding AvailableGroups}"
                  SelectedItem="{Binding SelectedTag}"
                  Margin="20,0,0,0"
                  Width="200">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsDataLoaded}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Style>
            </ComboBox>
        </StackPanel>

        <lvc:PieChart Grid.Row="2" Grid.Column="0"
                  Series="{Binding PieSeries}"
                  LegendPosition="Bottom"
                  LegendTextSize="10"
                  LegendTextPaint="{Binding WhiteColor}"
                  Margin="10,0,0,0">
            <lvc:PieChart.Style>
                <Style TargetType="lvc:PieChart">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDataLoaded}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </lvc:PieChart.Style>
        </lvc:PieChart>

        <lvc:PolarChart Grid.Row="1" Grid.Column="0"
            Series="{Binding PolarLineSeries}"
            AngleAxes="{Binding AngleAxes}"
            RadiusAxes="{Binding RadialAxes}">
            <lvc:PolarChart.Style>
                <Style TargetType="lvc:PolarChart">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDataLoaded}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </lvc:PolarChart.Style>
        </lvc:PolarChart>

        <lvc:CartesianChart Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
            TooltipFindingStrategy="CompareOnlyXTakeClosest"
            Series="{Binding СartesianSeries}"
            XAxes="{Binding XAxes}"
            YAxes="{Binding YAxes}"
            AnimationsSpeed="00:00:00.500"
            EasingFunction="{Binding Source={x:Static lvcore:EasingFunctions.SinIn}}"
            ZoomMode="X"
            Margin="0,0,10,0">
            <lvc:CartesianChart.Style>
                <Style TargetType="lvc:CartesianChart">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDataLoaded}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </lvc:CartesianChart.Style>
        </lvc:CartesianChart>

    </Grid>
</Window>