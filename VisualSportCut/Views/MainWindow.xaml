<Window Background="{StaticResource Background}" x:Class="VisualSportCut.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VisualSportCut"
        mc:Ignorable="d"
        Title="Статистика" MinHeight="600" MinWidth="800"
        xmlns:vm="clr-namespace:VisualSportCut.Presentation.ViewModels"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:lvcore="clr-namespace:LiveChartsCore;assembly=LiveChartsCore" d:DataContext="{d:DesignInstance Type=vm:MainViewModel}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="📂 Загрузить JSON" 
                Command="{Binding LoadFileCommand}"
                Padding="15,8"/>
            <ComboBox ItemsSource="{Binding GroupByTypes}"
              SelectedItem="{Binding SelectedGroupByType}"
              Style="{StaticResource ComboBox.Base}"/>

            <ComboBox ItemsSource="{Binding AvailableGroups}"
              SelectedItem="{Binding SelectedTagGroup}"
              Style="{StaticResource ComboBox.VisibleForTags}"/>

            <ComboBox ItemsSource="{Binding AvailablePeriods}"
              SelectedItem="{Binding SelectedPeriod}"
              Style="{StaticResource ComboBox.VisibleForPeriods}"/>

            <ComboBox ItemsSource="{Binding AvailableLabels}"
              SelectedItem="{Binding SelectedLabel}"
              Style="{StaticResource ComboBox.VisibleForLabels}"/>
        </StackPanel>

        <TabControl Grid.Row="1" 
                Background="Transparent"
                BorderThickness="0">

            <TabItem Header="📊 График">
                <lvc:CartesianChart TooltipFindingStrategy="CompareOnlyXTakeClosest"
                                Series="{Binding СartesianSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                ZoomMode="X"/>
            </TabItem>

            <TabItem Header="🥧 Диаграммы">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <lvc:PieChart Grid.Column="0"
                              Series="{Binding PieSeries}"
                              LegendPosition="Bottom"
                              LegendTextSize="14"
                              LegendTextPaint="{Binding WhiteColor}"
                              Margin="0,0,10,0"
                              MaxHeight="500"
                              MaxWidth="800"/>

                    <lvc:PolarChart Grid.Column="1"
                                Series="{Binding PolarLineSeries}"
                                AngleAxes="{Binding AngleAxes}"
                                RadiusAxes="{Binding RadialAxes}"
                                Margin="10,0,0,0"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>

</Window>